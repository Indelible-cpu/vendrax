generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum RoleName {
  SUPER_ADMIN
  ADMIN
  CASHIER
}

enum BranchStatus {
  ACTIVE
  INACTIVE
}

enum PaymentMode {
  CASH
  CARD
  MOBILE_MONEY
  CREDIT
}

enum SaleStatus {
  COMPLETED
  PENDING
  DELETED
}

model Role {
  id          Int      @id @default(autoincrement())
  name        RoleName @unique
  description String?
  users       User[]
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  roleId    Int
  role      Role     @relation(fields: [roleId], references: [id])
  branchId  Int?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  sales     Sale[]
  expenses  Expense[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deleted   Boolean  @default(false)
}

model Branch {
  id        Int          @id @default(autoincrement())
  name      String
  location  String?
  phone     String?
  status    BranchStatus @default(ACTIVE)
  users     User[]
  products  Product[]
  sales     Sale[]
  expenses  Expense[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Category {
  id       Int       @id @default(autoincrement())
  slug     String    @unique
  title    String
  products Product[]
}

model Product {
  id          Int       @id @default(autoincrement())
  categoryId  Int
  category    Category  @relation(fields: [categoryId], references: [id])
  sku         String?   @unique
  name        String
  description String?
  costPrice   Decimal   @db.Decimal(10, 2)
  sellPrice   Decimal   @db.Decimal(10, 2)
  taxRate     Decimal   @default(0.00) @db.Decimal(5, 2)
  quantity    Int       @default(0)
  isService   Boolean   @default(false)
  branchId    Int?
  branch      Branch?   @relation(fields: [branchId], references: [id])
  deleted     Boolean   @default(false)
  
  // Sync fields
  synced      Boolean   @default(true)
  deviceId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  saleItems   SaleItem[]
}

model Customer {
  id            Int      @id @default(autoincrement())
  fullname      String
  phone         String
  email         String?
  address       String?
  loyaltyPoints Int      @default(0)
  idNumber      String?
  village       String?
  locationId    String?
  livePhoto     String?  @db.Text
  sales         Sale[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Sale {
  id           String      @id @default(cuid())
  invoiceNo    String      @unique
  receiptNo    String?
  userId       Int
  user         User        @relation(fields: [userId], references: [id])
  branchId     Int?
  branch       Branch?     @relation(fields: [branchId], references: [id])
  customerId   Int?
  customer     Customer?   @relation(fields: [customerId], references: [id])
  
  subtotal     Decimal     @db.Decimal(10, 2)
  discount     Decimal     @default(0.00) @db.Decimal(10, 2)
  total        Decimal     @db.Decimal(10, 2)
  paid         Decimal     @db.Decimal(10, 2)
  changeDue    Decimal     @default(0.00) @db.Decimal(10, 2)
  profit       Decimal     @db.Decimal(10, 2)
  paymentMode  PaymentMode @default(CASH)
  status       SaleStatus  @default(COMPLETED)
  
  taxRate      Decimal     @default(0.00) @db.Decimal(5, 2)
  taxAmount    Decimal     @default(0.00) @db.Decimal(10, 2)
  isCredit     Boolean     @default(false)
  dueDate      DateTime?
  
  itemsCount   Int         @default(0)
  items        SaleItem[]
  
  // Offline Sync Logic
  synced       Boolean     @default(false) // Sales usually start unsynced on device
  deviceId     String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model SaleItem {
  id            Int      @id @default(autoincrement())
  saleId        String
  sale          Sale     @relation(fields: [saleId], references: [id])
  productId     Int
  product       Product  @relation(fields: [productId], references: [id])
  productName   String
  unitPrice     Decimal  @db.Decimal(10, 2)
  quantity      Int      @default(1)
  discount      Decimal  @default(0.00) @db.Decimal(10, 2)
  lineTotal     Decimal  @db.Decimal(10, 2)
  profit        Decimal  @db.Decimal(10, 2)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Expense {
  id            Int      @id @default(autoincrement())
  category      String
  amount        Decimal  @db.Decimal(12, 2)
  description   String?
  paymentMethod String   @default("Cash")
  expenseDate   DateTime
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  branchId      Int?
  branch        Branch?  @relation(fields: [branchId], references: [id])
  createdAt     DateTime @default(now())
}

model SyncLog {
  id        Int      @id @default(autoincrement())
  deviceId  String
  userId    Int
  action    String   // e.g., "UPLOAD_SALES", "DOWNLOAD_PRODUCTS"
  status    String   // "SUCCESS", "FAILURE"
  details   String?  @db.Text
  createdAt DateTime @default(now())
}
